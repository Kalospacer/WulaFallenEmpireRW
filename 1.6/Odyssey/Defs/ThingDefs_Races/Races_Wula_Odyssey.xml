    <uiIconPath>Wula/Things/Wula_AI_Bomb_Mother/Wula_AI_Bomb_Mother_Icon</uiIconPath>
  </ThingDef>
  <AbilityDef>
    <defName>Wula_AI_Engineer_Mother_Attack_Ability</defName>
    <label>部署低角护盾</label>
    <description>向所在单元格部署一个低角护盾，该护盾不会由于攻击而过载，但是会在几十秒后烧毁。</description>
