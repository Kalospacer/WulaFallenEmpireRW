        </effects>
      </li>
    </dismissEffects>
    <options>
      <li>
        <label>触发袭击</label>
        <optionEffects>
          <li>
            <effects>
              <li Class="WulaFallenEmpire.Effect_CloseDialog" />
            </effects>
          </li>
        </optionEffects>
      </li>
      <li>
        <label>关闭</label>
        <optionEffects>
          <li>
            <effects>
              <li Class="WulaFallenEmpire.Effect_CloseDialog" />
            </effects>
          </li>
        </optionEffects>
      </li>
    </options>
