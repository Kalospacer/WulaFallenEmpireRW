<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- 扩展原版机械体表格，添加我们的自定义列 -->
  <PawnTableDef>
    <defName>Mechs</defName>
    <columns>
      <li>Label</li>
      <li>WULA_DroneWorkMode</li>
      <li>WULA_DroneEnergy</li>
      <li>ControlGroup</li>
      <li>Overseer</li>
      <li>AllowedArea</li>
      <li>WorkPriority</li>
