        <minSpeedForStage1>1.0</minSpeedForStage1>
        <minSpeedForStage2>2.0</minSpeedForStage2>
        <speedHistoryFrameCount>15</speedHistoryFrameCount>
        <stageTransitionCooldownTicks>3</stageTransitionCooldownTicks>
        
