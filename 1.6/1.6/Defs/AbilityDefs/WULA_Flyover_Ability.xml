      <li Class="WulaFallenEmpire.CompProperties_AbilitySpawnFlyOver">
        <flyOverDef>WULA_Fighter_B</flyOverDef>
        <flyOverType>GroundStrafing</flyOverType>
        <flightSpeed>3</flightSpeed>
