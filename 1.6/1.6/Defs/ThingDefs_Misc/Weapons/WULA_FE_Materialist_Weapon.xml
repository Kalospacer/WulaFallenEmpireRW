          </points>
        </beamLineFleckChanceCurve>

        <!-- 攻击目标设置 -->
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>

        <!-- 爆炸参数 -->
        <enableExplosion>true</enableExplosion>
        <explosionShotInterval>2</explosionShotInterval>
