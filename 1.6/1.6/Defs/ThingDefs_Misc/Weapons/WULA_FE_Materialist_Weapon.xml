        <homingSpeed>0</homingSpeed>
        <initRotateAngle>0</initRotateAngle>
        <destroyTicksAfterLosingTrack>
          <min>60</min>
          <max>120</max>
        </destroyTicksAfterLosingTrack>
        <tailFleckDef>WULA_GunTail_Plasma</tailFleckDef>
        <impactThreshold>1</impactThreshold>
