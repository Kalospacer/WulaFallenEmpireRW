  <AlienRace.AlienBackstoryDef>
    <defName>WULA_Child_Backstory99</defName>
    <ignoreIllegalLabelCharacterConfigError>False</ignoreIllegalLabelCharacterConfigError>
    <slot>Childhood</slot>
    <title>产地：未知</title>
    <titleShort>未知产地</titleShort>
    <description>[PAWN_nameDef] 的产地无法追溯——或许是某个星区的高仿品，或许是被回收之后非法再加工的机体，总之她们身体上的机体编号要么是伪造的，要么就干脆没有机体编号。\n\n这些野生的机械乌拉什么都会一点，但是没什么特别擅长的。</description>
    <skillGains>
