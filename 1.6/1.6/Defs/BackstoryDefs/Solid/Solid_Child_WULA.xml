  <AlienRace.AlienBackstoryDef>
    <defName>WULA_Child_Backstory04</defName>
    <ignoreIllegalLabelCharacterConfigError>False</ignoreIllegalLabelCharacterConfigError>
    <slot>Childhood</slot>
    <title>产地：德尔塔</title>
    <titleShort>德尔塔</titleShort>
    <description>[PAWN_nameDef] 是产自德尔塔星区的合成人。德尔塔星区是真正的堡垒星区，无数装配工厂迸溅着硫磺与火焰，战争机械是这里唯一的产物——她们一踏出生产线，便会加入"军团"的洪流中，奔赴乌拉帝国的战场。\n\n此处生产的合成人作为专门的战争机械而设计，结构简单易维护，拥有无可争议的战斗能力，但是不太擅长其他的工作。</description>
    <skillGains>
      <Shooting>5</Shooting>
      <Melee>5</Melee>
    </skillGains>
    <spawnCategories>
      <li>Wula_Backstory_Categories</li>
    </spawnCategories>
    <requiredWorkTags>None</requiredWorkTags>
    <forcedHediffs>
      <li>WULA_Child_Backstory04_Hediff</li>
    </forcedHediffs>
    <forcedTraitsChance>
    </forcedTraitsChance>
  </AlienRace.AlienBackstoryDef>
