        <statOffsets>
          <MiningSpeed>0.75</MiningSpeed>
          <MiningYield>0.5</MiningYield>
          <ConstructionSpeed>0.75</ConstructionSpeed>
          <ConstructSuccessChance>0.5</ConstructSuccessChance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
  <AlienRace.AlienBackstoryDef>
    <defName>WULA_Child_Backstory03</defName>
    <ignoreIllegalLabelCharacterConfigError>False</ignoreIllegalLabelCharacterConfigError>
    <slot>Childhood</slot>
    <title>产地：皇宫区</title>
    <titleShort>皇宫区</titleShort>
    <description>[PAWN_nameDef] 是产自皇宫区的合成人。皇宫区是乌拉帝国政治和权力的核心，在这片星区生产的东西一般都是皇室专供，不会外流到其他星区——当然也有例外就是了。\n\n此处生产的合成人通常是比其他星区的合成人更加精致和风度翩翩，这使得她们在社交和艺术上拥有得天独厚的优势。</description>
    <skillGains>
      <Artistic>5</Artistic>
      <Social>5</Social>
    </skillGains>
    <spawnCategories>
      <li>Wula_Backstory_Categories</li>
    </spawnCategories>
    <requiredWorkTags>None</requiredWorkTags>
    <forcedHediffs>
      <li>WULA_Child_Backstory03_Hediff</li>
    </forcedHediffs>
    <forcedTraitsChance>
    </forcedTraitsChance>
  </AlienRace.AlienBackstoryDef>
