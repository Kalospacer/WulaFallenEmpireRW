    <defaultChallengeRating>1</defaultChallengeRating>    <!-- 挑战等级（星级） -->
    <isRootSpecial>true</isRootSpecial>    <!-- 特殊任务 -->
    <defaultCharity>false</defaultCharity>    <!-- 是否仁善 -->
