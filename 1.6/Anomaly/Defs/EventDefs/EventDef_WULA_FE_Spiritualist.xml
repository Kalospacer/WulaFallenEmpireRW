            <type>Int</type>
          </li>
        </effects>
      </li>
    </immediateEffects>
    <options>
      <li>
        <label>你们是谁？</label>
        <optionEffects>
          <li>
            <effects>
              <li Class="WulaFallenEmpire.Effect_CloseDialog" />
            </effects>
          </li>
        </optionEffects>
      </li>
      <li>
